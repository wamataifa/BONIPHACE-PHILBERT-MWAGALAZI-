# Environment Variables Configuration

## Application Settings
APP_NAME=Clinic Management System
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

## Database Configuration

### For Local Development (SQLite)
# No configuration needed - uses clinic_management.sqlite by default

### For Production (AWS RDS MySQL)
DB_CONNECTION=mysql
DB_HOST=clinic-management-db.xxxxx.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_DATABASE=clinic_management
DB_USERNAME=admin
DB_PASSWORD=your_secure_password_here

## AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_ACCOUNT_ID=123456789012

## Session Configuration
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=localhost
CSRF_ENABLED=true

## Application Features
SITE_NAME=Clinic Management
LOGO_PATH=/assets/logo.png
TIMEZONE=Africa/Dar_es_Salaam

## Email Configuration (Optional)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@clinic.local
MAIL_FROM_NAME=Clinic Management

## Security
HASH_ALGORITHM=bcrypt
HASH_COST=10

## API Configuration (if needed)
API_DEBUG=false
API_RATE_LIMIT=100

## Logging
LOG_CHANNEL=single
LOG_LEVEL=debug

## Cache Configuration
CACHE_DRIVER=file
CACHE_TTL=3600

## File Upload
MAX_UPLOAD_SIZE=5M
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

## Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_TIME=03:00

## Notes:
# - For local development, just use the defaults and it will use SQLite
# - For AWS deployment, populate the RDS credentials
# - Never commit actual passwords - use AWS Secrets Manager in production
# - Regenerate API keys and secrets periodically
